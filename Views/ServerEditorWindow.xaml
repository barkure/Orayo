<Window
    x:Class="Orayo.Views.ServerEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,24,8,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,16,0">
            <StackPanel Spacing="12" MinWidth="420">
                <TextBlock Text="基础信息" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBox x:Name="NameTextBox" Header="名称" PlaceholderText="例如：JP-01" />
                <ComboBox x:Name="ProtocolComboBox" Header="协议" SelectionChanged="ProtocolComboBox_SelectionChanged">
                    <ComboBoxItem Content="Shadowsocks" Tag="ss" />
                    <ComboBoxItem Content="VMess" Tag="vmess" />
                    <ComboBoxItem Content="VLESS" Tag="vless" />
                    <ComboBoxItem Content="Trojan" Tag="trojan" />
                    <ComboBoxItem Content="Hysteria 2" Tag="hysteria2" />
                </ComboBox>
                <TextBox x:Name="HostTextBox" Header="地址" PlaceholderText="server.example.com" />
                <NumberBox x:Name="PortNumberBox" Header="端口" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Compact" />

                <TextBlock x:Name="ProtocolSettingsTitle" Text="协议设置" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
                <PasswordBox x:Name="PasswordTextBox" Header="密码" />
                <TextBox x:Name="EncryptionTextBox" Header="加密方式" PlaceholderText="例如：aes-128-gcm" />
                <TextBox x:Name="UuidTextBox" Header="UUID" />
                <NumberBox x:Name="AlterIdNumberBox" Header="AlterId" Minimum="0" Maximum="999" SpinButtonPlacementMode="Compact" />
                <ComboBox x:Name="NetworkComboBox" Header="传输方式" SelectionChanged="NetworkComboBox_SelectionChanged">
                    <x:String>tcp</x:String>
                    <x:String>ws</x:String>
                    <x:String>grpc</x:String>
                    <x:String>xhttp</x:String>
                </ComboBox>
                <TextBox x:Name="PathTextBox" Header="Path / ServiceName" />
                <TextBox x:Name="WsHostTextBox" Header="Host Header" />

                <TextBlock x:Name="TransportSecurityTitle" Text="传输安全" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
                <ComboBox x:Name="SecurityComboBox" Header="类型" SelectionChanged="SecurityComboBox_SelectionChanged">
                    <ComboBoxItem x:Name="SecurityNoneItem" Content="none" Tag="none" />
                    <ComboBoxItem x:Name="SecurityTlsItem" Content="tls" Tag="tls" />
                    <ComboBoxItem x:Name="SecurityRealityItem" Content="reality" Tag="reality" />
                </ComboBox>
                <TextBox x:Name="SniTextBox" Header="SNI" />
                <TextBox x:Name="FingerprintTextBox" Header="Fingerprint" PlaceholderText="chrome" />
                <CheckBox x:Name="AllowInsecureCheckBox" Content="允许不安全证书" />
                <TextBox x:Name="EchConfigListTextBox" Header="ECH ConfigList" />
                <ComboBox x:Name="EchForceQueryComboBox" Header="ECH Force Query">
                    <ComboBoxItem Content="none" Tag="" />
                    <ComboBoxItem Content="half" Tag="half" />
                    <ComboBoxItem Content="full" Tag="full" />
                </ComboBox>
                <TextBox x:Name="PublicKeyTextBox" Header="REALITY Public Key" />
                <TextBox x:Name="ShortIdTextBox" Header="REALITY Short ID" />
                <TextBox x:Name="SpiderXTextBox" Header="REALITY SpiderX" />
                <TextBox x:Name="FlowTextBox" Header="VLESS Flow" />
                <TextBox x:Name="VlessEncryptionTextBox" Header="VLESS Encryption" />

                <TextBlock Text="高级配置" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
                <TextBox x:Name="FinalmaskTextBox" Header="FinalMask (JSON)" AcceptsReturn="True" TextWrapping="NoWrap" Height="104" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,0,16,0">
            <Button x:Name="SaveButton" Style="{StaticResource AccentButtonStyle}" Content="添加" MinWidth="96" Click="SaveButton_Click" />
            <Button Content="取消" MinWidth="96" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>






