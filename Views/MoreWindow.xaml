<Window
    x:Class="Orayo.Views.MoreWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Orayo.Helpers"
    mc:Ignorable="d"
    Title="{local:Localize Key=TitleMore}">

    <Grid Padding="24,16,0,24" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarGrid" Margin="-24,-16,-24,0" Padding="24,12,24,12" Background="Transparent">
            <TextBlock x:Name="TitleBarTextBlock" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,24,0">
            <StackPanel Spacing="10">
                <StackPanel Spacing="6">
                    <TextBlock Text="{local:Localize Key=TitleMore}" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{local:Localize Key=MoreDescription}" Opacity="0.68" />
                </StackPanel>

                <Border Padding="16" CornerRadius="5" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{local:Localize Key=AutoStart}" FontWeight="SemiBold" VerticalAlignment="Center" />

                <ToggleButton x:Name="AutoStartToggleButton" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Width="96" Click="AutoStartToggleButton_Click" />
            </Grid>
        </Border>

                <Border Padding="16" CornerRadius="5" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock Text="Xray-core" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock x:Name="VersionTextBlock" Text="{local:Localize Key=Loading}" Opacity="0.72" VerticalAlignment="Center" />
                        <HyperlinkButton x:Name="CommitLinkButton"
                                         Visibility="Collapsed"
                                         Padding="0"
                                         MinWidth="0"
                                         VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Button x:Name="UpdateCoreButton" Grid.Column="1" Content="{local:Localize Key=ButtonUpdate}" MinWidth="96" Click="UpdateCoreButton_Click" />
            </Grid>
        </Border>

                <Border Padding="16" CornerRadius="5" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock Text="{local:Localize Key=GeoFiles}" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{local:Localize Key=GeoDescription}" Opacity="0.72" VerticalAlignment="Center" />
                        <HyperlinkButton Content="Loyalsoldier/v2ray-rules-dat"
                                         NavigateUri="https://github.com/Loyalsoldier/v2ray-rules-dat"
                                         Padding="0"
                                         MinWidth="0"
                                         VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Button x:Name="UpdateGeofilesButton" Grid.Column="1" Content="{local:Localize Key=ButtonUpdate}" MinWidth="96" Click="UpdateGeofilesButton_Click" />
            </Grid>
        </Border>

                <Border Padding="16" CornerRadius="5" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock Text="{local:Localize Key=LoopbackManager}" FontWeight="SemiBold" />
                    <TextBlock Text="{local:Localize Key=LoopbackDescription}" Opacity="0.72" TextWrapping="Wrap" />
                </StackPanel>

                <Button x:Name="OpenLoopbackUtilityButton" Grid.Column="1" Content="{local:Localize Key=ButtonOpen}" MinWidth="96" Click="OpenLoopbackUtilityButton_Click" />
            </Grid>
        </Border>

                <Border Padding="16" CornerRadius="5" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{local:Localize Key=SettingsLanguage}" FontWeight="SemiBold" VerticalAlignment="Center" />

                <ComboBox x:Name="LanguageComboBox" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="96" SelectionChanged="LanguageComboBox_SelectionChanged">
                    <ComboBoxItem Content="简体中文" Tag="zh-Hans" />
                    <ComboBoxItem Content="English" Tag="en" />
                </ComboBox>
            </Grid>
        </Border>

                <Border Padding="16" CornerRadius="5" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock Text="{local:Localize Key=AboutOrayo}" FontWeight="SemiBold" />
                    <TextBlock Text="{local:Localize Key=AboutDescription}" Opacity="0.72" TextWrapping="Wrap" />
                    <TextBlock x:Name="AppVersionTextBlock" Text="{local:Localize Key=AppVersionLoading}" Opacity="0.72" TextWrapping="Wrap" />
                    <HyperlinkButton Content="GitHub - barkure/Orayo"
                                     NavigateUri="https://github.com/barkure/Orayo"
                                     Padding="0"
                                     MinWidth="0"
                                     HorizontalAlignment="Left" />
                </StackPanel>

                <Button x:Name="CheckAppUpdateButton" Grid.Column="1" Content="{local:Localize Key=ButtonCheckUpdate}" MinWidth="96" Click="CheckAppUpdateButton_Click" />
            </Grid>
        </Border>

                <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Opacity="0.72" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
