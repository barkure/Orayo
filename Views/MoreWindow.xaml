<Window
    x:Class="Orayo.Views.MoreWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="更多">

    <Grid Padding="24,16,24,24" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarGrid" Margin="-24,-16,-24,0" Padding="24,12,24,12" Background="Transparent">
            <TextBlock x:Name="TitleBarTextBlock" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Grid>

        <StackPanel Grid.Row="1" Spacing="6">
            <TextBlock Text="更多" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Xray 内核、Geo 数据文件和软件信息" Opacity="0.68" />
        </StackPanel>

        <Border Grid.Row="2" Padding="16" CornerRadius="5" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="开机自启动" FontWeight="SemiBold" VerticalAlignment="Center" />

                <ToggleButton x:Name="AutoStartToggleButton" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Width="96" Click="AutoStartToggleButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="3" Padding="16" CornerRadius="5" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock Text="Xray-core" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock x:Name="VersionTextBlock" Text="读取中..." Opacity="0.72" VerticalAlignment="Center" />
                        <HyperlinkButton x:Name="CommitLinkButton"
                                         Visibility="Collapsed"
                                         Padding="0"
                                         MinWidth="0"
                                         VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Button x:Name="UpdateCoreButton" Grid.Column="1" Content="更新" MinWidth="96" Click="UpdateCoreButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="4" Padding="16" CornerRadius="5" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock Text="Geo 数据文件" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="geoip.dat 和 geosite.dat 来自" Opacity="0.72" VerticalAlignment="Center" />
                        <HyperlinkButton Content="Loyalsoldier/v2ray-rules-dat"
                                         NavigateUri="https://github.com/Loyalsoldier/v2ray-rules-dat"
                                         Padding="0"
                                         MinWidth="0"
                                         VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Button x:Name="UpdateGeofilesButton" Grid.Column="1" Content="更新" MinWidth="96" Click="UpdateGeofilesButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="5" Padding="16" CornerRadius="5" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="8">
                <TextBlock Text="关于 Orayo" FontWeight="SemiBold" />
                <TextBlock Text="一个适用于 Windows 的现代化 Xray 客户端" Opacity="0.72" TextWrapping="Wrap" />
                <HyperlinkButton Content="GitHub - barkure/Orayo"
                                 NavigateUri="https://github.com/barkure/Orayo"
                                 Padding="0"
                                 MinWidth="0"
                                 HorizontalAlignment="Left" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="6" x:Name="StatusTextBlock" VerticalAlignment="Center" Opacity="0.72" TextWrapping="Wrap" />
    </Grid>
</Window>
