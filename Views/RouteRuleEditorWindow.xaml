<Window
    x:Class="Orayo.Views.RouteRuleEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarGrid" Margin="-24,-24,-24,0" Padding="24,12,24,12" Background="Transparent">
            <TextBlock x:Name="TitleBarTextBlock" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel Spacing="16" MaxWidth="560" Padding="4,0,16,0">
                <Grid ColumnSpacing="12" RowSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="6">
                        <TextBlock Text="名称" FontWeight="SemiBold" />
                        <TextBox x:Name="NameTextBox" PlaceholderText="例如：Google 走代理" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                        <TextBlock Text="匹配类型" FontWeight="SemiBold" />
                        <ComboBox x:Name="TypeComboBox">
                            <x:String>domain</x:String>
                            <x:String>ip</x:String>
                            <x:String>process</x:String>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                        <TextBlock Text="目标出站" FontWeight="SemiBold" />
                        <ComboBox x:Name="OutboundComboBox">
                            <x:String>proxy</x:String>
                            <x:String>direct</x:String>
                            <x:String>block</x:String>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="6">
                        <TextBlock Text="匹配内容" FontWeight="SemiBold" />
                        <TextBox x:Name="MatchTextBox"
                                 PlaceholderText="例如：geosite:google / geoip:private / WeChat.exe"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="120" />
                        <TextBlock Text="域名支持 geosite，IP 支持 geoip/CIDR，进程支持 exe 名称。" Opacity="0.6" TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBlock x:Name="ErrorTextBlock"
                               Grid.Row="3"
                               Grid.ColumnSpan="2"
                               Text="请填写匹配内容。"
                               Foreground="IndianRed"
                               Visibility="Collapsed" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,0,8,0">
            <Button Style="{StaticResource AccentButtonStyle}" Content="保存" MinWidth="96" Click="SaveButton_Click" />
            <Button Content="取消" MinWidth="96" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>



